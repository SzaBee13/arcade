import { Metadata } from "next";
import fs from "fs";
import path from "path";

export const metadata: Metadata = {
  title: "Terms of Service" as any,
};

export default function TermsPage() {
  const markdown = fs.readFileSync(path.join(process.cwd(), "app", "legal", "md", "terms.md"), "utf8");
  return <article className="prose prose-invert max-w-none" dangerouslyDangerouslySetInnerHTML={{ __html: markdown }} />;
}
